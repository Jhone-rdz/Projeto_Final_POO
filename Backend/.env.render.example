# ============================================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE PARA RENDER
# Copie estas variáveis para a aba "Environment" do seu Web Service no Render
# ============================================================================

# DJANGO (OBRIGATÓRIO)
SECRET_KEY=change-me-to-a-random-secure-key-with-at-least-32-characters
DEBUG=False

# HOSTS (OBRIGATÓRIO - cole o domínio do Render)
ALLOWED_HOSTS=reserveaqui-api.onrender.com
CSRF_TRUSTED_ORIGINS=https://reserveaqui-api.onrender.com

# DATABASE (OBRIGATÓRIO - cole a connection string do PostgreSQL do Render)
DATABASE_URL=postgresql://user:password@vpc-xxxx.c.db.onrender.com:5432/dbname
POSTGRES_CONN_MAX_AGE=60
POSTGRES_SSL_REQUIRE=True

# CORS (OBRIGATÓRIO - adicione o domínio do frontend no Netlify)
CORS_ALLOWED_ORIGINS=https://seu-frontend.netlify.app

# FRONTEND (OBRIGATÓRIO)
FRONTEND_URL=https://seu-frontend.netlify.app

# EMAIL (OPCIONAL - se quiser habilitar recuperação de senha)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=seu-email@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-app-google

# SEGURANÇA (RECOMENDADO)
SECURE_SSL_REDIRECT=False
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO https

# SENTRY (OPCIONAL - para monitoramento de erros)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
