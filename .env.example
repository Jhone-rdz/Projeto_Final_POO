# Django
SECRET_KEY=troque-esta-chave-em-producao
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://seu-dominio.com

# Banco (PostgreSQL)
DB_ENGINE=postgres
POSTGRES_DB=reserveaqui
POSTGRES_USER=reserveaqui
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://seu-dominio.com

# E-mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@reserveaqui.com
EMAIL_HOST_PASSWORD=senha-app-email
DEFAULT_FROM_EMAIL=noreply@reserveaqui.com

# Frontend
FRONTEND_URL=https://seu-dominio.com

# Segurança por proxy TLS (habilite quando houver HTTPS real)
SECURE_SSL_REDIRECT=False
