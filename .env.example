# =============================
# Exemplo de .env para ReserveAqui
# =============================
# Instruções rápidas:
# - Copie este arquivo para `.env` e preencha os valores antes de executar.
# - NÃO comite o arquivo `.env` em repositórios públicos.
# - Use GitHub Secrets / CI variables para valores sensíveis em CI/CD.


## -----------------------------
## Obrigatórias (defina para produção)
## -----------------------------
# Chave secreta do Django (sempre mantenha privada)
SECRET_KEY=troque-esta-chave-em-producao

# Modo debug: use False em produção (settings deve converter string para bool)
DEBUG=False

# Hosts permitidos (vírgula-separados). Em produção coloque seu domínio.
ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.com

# Origens confiáveis para CSRF (vírgula-separados)
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://seu-dominio.com


## -----------------------------
## Banco de dados (Postgres) — obrigatórias se usar Postgres
## -----------------------------
# Define engine; manter 'postgres' para usar o serviço `db` do docker-compose
DB_ENGINE=postgres
POSTGRES_DB=reserveaqui
POSTGRES_USER=reserveaqui
POSTGRES_PASSWORD=troque-esta-senha
# Host do Postgres (no docker-compose é 'db')
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60


## -----------------------------
## Recomendadas / Operacionais
## -----------------------------
# CORS: se True, ignora CORS_ALLOWED_ORIGINS.
CORS_ALLOW_ALL_ORIGINS=False
# Lista de origens permitidas (vírgula-separadas)
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://seu-dominio.com

# URL pública do frontend (usada em e-mails, redirect etc.)
FRONTEND_URL=https://seu-dominio.com


## -----------------------------
## E-mail (configure com credenciais de produção)
## -----------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@reserveaqui.com
EMAIL_HOST_PASSWORD=senha-app-email
DEFAULT_FROM_EMAIL=noreply@reserveaqui.com


## -----------------------------
## Observabilidade / Sentry
## -----------------------------
# Deixe em branco para desabilitar em ambientes sem Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=False
SENTRY_ENABLE_LOGS=False
# Variáveis expo/Vite (frontend)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_SEND_DEFAULT_PII=False
VITE_SENTRY_ENABLE_LOGS=False


## -----------------------------
## Segurança (HTTPS / cookies)
## -----------------------------
# Habilitar quando estiver atrás de proxy TLS/HTTPS real
SECURE_SSL_REDIRECT=False
# Em produção, considere também:
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True


## -----------------------------
## Alternativas e dicas
## -----------------------------
# - Se quiser usar DATABASE_URL em vez de variáveis individuais, adicione:
# DATABASE_URL=postgres://user:password@host:5432/dbname
# - Para desenvolvimento rápido sem Postgres, ajuste `DB_ENGINE=sqlite` e remova
#   as variáveis POSTGRES_* (ou mantenha ambas opções e trate em settings).


## -----------------------------
## Nota final
## -----------------------------
# - Gere `SECRET_KEY` seguro em produção (ex.: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())").
# - Nunca compartilhe `EMAIL_HOST_PASSWORD`, `POSTGRES_PASSWORD` ou chaves privadas.
# - Use o arquivo `.env` local apenas para desenvolvimento; em CI use Secrets.

